{
  "name": "hstorage-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "hstorage": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "test:pre-commit": "bun test test/commands test/lib test/middleware test/types test/security test/e2e/ test/helpers test/smoke.test.ts test/debug-folder-share.test.ts",
    "build": "bun build --compile src/index.ts --outfile hcli",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "incur": "^0.3.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
