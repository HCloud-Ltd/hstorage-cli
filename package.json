{
  "name": "hstorage-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "hstorage": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun build --compile src/index.ts --outfile hcli",
    "generate:types": "bun scripts/generate-types.ts",
    "prebuild": "bun run generate:types",
    "pretest": "bun run generate:types",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "incur": "0.3.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  },
  "patchedDependencies": {
    "incur@0.3.4": "patches/incur@0.3.4.patch"
  }
}
